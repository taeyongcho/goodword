    [
      {
        "text": "삶이 있는 한 희망은 있다",
        "author": "키케로"
      },
      {
        "text": "산다는것 그것은 치열한 전투이다",
        "author": "로망로랑"
      },
      {
        "text": "언제나 현재에 집중할수 있다면 행복할것이다",
        "author": "파울로 코엘료"
      },
      {
        "text": "피할수 없으면 즐겨라",
        "author": "로버트 엘리엇"
      }
      {
     "text": "하기싫어? 그냥 하기는거지 뭐",
     "author": "조태용"
      }
   
    ]
    
